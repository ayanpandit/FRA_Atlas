# Frontend .env.example - copy to .env and fill values
# Vite environment variables use the VITE_ prefix
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: database or other local values used in frontend dev
DATABASE_URL="postgresql+asyncpg://fra_user:password@localhost/fra_db"
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
VITE_BACKEND_URL=http://localhost:5000

# Village Directory APIs
VITE_COWIN_API_URL=https://cdn-api.co-vin.in/api/v2/admin/location
VITE_DATA_GOV_API_URL=https://api.data.gov.in/resource/9115b89c-7a80-4f54-9b06-21086e0f0bd7
VITE_DATA_GOV_API_KEY=579b464db66ec23bdd000001cdd3946e44ce4aad7209ff7b23ac571b
# For production builds, override VITE_BACKEND_URL with your hosted backend URL
