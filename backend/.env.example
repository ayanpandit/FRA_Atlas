# Backend .env.example - copy to .env and fill values
# Database connection (example)
DATABASE_URL="postgresql+asyncpg://fra_user:password@localhost/fra_db"

# Local Tesseract path (Windows example)
TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Supabase credentials (do NOT commit real keys)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Third-party API keys
RAPIDAPI_KEY=your-rapidapi-key
GEMINI_API_KEY=your-gemini-or-google-key

# Earth Engine configuration (required for Render deploy)
EE_PROJECT_ID=fra-a-472418
# Provide credentials using one of the options below:
# GOOGLE_APPLICATION_CREDENTIALS=/etc/secrets/ee-service-account.json
# EE_SERVICE_ACCOUNT_JSON={"type":"service_account", ...}
# EE_SERVICE_ACCOUNT_EMAIL=service-account@your-project.iam.gserviceaccount.com

# Server config
PORT=5000
# Frontend public URL to allow CORS (e.g. https://fra-atlas.onrender.com)
FRONTEND_URL=https://your-frontend-url

# If you're also deploying the frontend, set VITE_BACKEND_URL in the frontend's
# .env files instead of here.
